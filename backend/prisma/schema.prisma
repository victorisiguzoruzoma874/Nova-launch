generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Token {
  id            String   @id @default(uuid())
  address       String   @unique
  creator       String
  name          String
  symbol        String
  decimals      Int      @default(18)
  totalSupply   BigInt
  initialSupply BigInt
  totalBurned   BigInt   @default(0)
  burnCount     Int      @default(0)
  metadataUri   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  burnRecords BurnRecord[]
  analytics   Analytics[]

  @@index([address])
  @@index([creator])
  @@index([createdAt])
  @@index([totalSupply])
  @@index([totalBurned])
  @@index([burnCount])
  @@index([name])
  @@index([symbol])
}

model BurnRecord {
  id         String   @id @default(uuid())
  tokenId    String
  from       String
  amount     BigInt
  burnedBy   String
  isAdminBurn Boolean @default(false)
  txHash     String   @unique
  timestamp  DateTime @default(now())

  token Token @relation(fields: [tokenId], references: [id])

  @@index([tokenId])
  @@index([from])
  @@index([txHash])
  @@index([timestamp])
}

model BuybackCampaign {
  id              Int      @id @default(autoincrement())
  tokenAddress    String
  totalAmount     String
  executedAmount  String   @default("0")
  currentStep     Int      @default(0)
  totalSteps      Int
  status          CampaignStatus @default(ACTIVE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  steps           BuybackStep[]

  @@index([status])
  @@index([tokenAddress])
  @@index([createdAt])
}

model BuybackStep {
  id              Int      @id @default(autoincrement())
  campaignId      Int
  stepNumber      Int
  amount          String
  status          StepStatus @default(PENDING)
  executedAt      DateTime?
  txHash          String?
  
  campaign        BuybackCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, stepNumber])
  @@index([status])
}

enum StepStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id         String   @id @default(uuid())
  address    String   @unique
  createdAt  DateTime @default(now())
  lastActive DateTime @updatedAt

  @@index([address])
}

model Analytics {
  id            String   @id @default(uuid())
  tokenId       String
  date          DateTime @db.Date
  burnVolume    BigInt   @default(0)
  burnCount     Int      @default(0)
  uniqueBurners Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  token Token @relation(fields: [tokenId], references: [id])

  @@unique([tokenId, date])
  @@index([tokenId])
  @@index([date])
}

model Stream {
  id          String   @id @default(uuid())
  streamId    Int      @unique
  creator     String
  recipient   String
  amount      BigInt
  metadata    String?
  status      StreamStatus @default(CREATED)
  txHash      String   @unique
  createdAt   DateTime @default(now())
  claimedAt   DateTime?
  cancelledAt DateTime?

  @@index([creator])
  @@index([recipient])
  @@index([status])
  @@index([createdAt])
}

enum StreamStatus {
  CREATED
  CLAIMED
  CANCELLED
}

model Proposal {
  id          String   @id @default(uuid())
  proposalId  Int      @unique
  tokenId     String
  proposer    String
  title       String
  description String?
  proposalType ProposalType
  status      ProposalStatus @default(ACTIVE)
  startTime   DateTime
  endTime     DateTime
  quorum      BigInt
  threshold   BigInt
  metadata    String?
  txHash      String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  executedAt  DateTime?
  cancelledAt DateTime?

  votes       Vote[]
  executions  ProposalExecution[]

  @@index([tokenId])
  @@index([proposer])
  @@index([status])
  @@index([startTime])
  @@index([endTime])
  @@index([createdAt])
}

model Vote {
  id         String   @id @default(uuid())
  proposalId String
  voter      String
  support    Boolean
  weight     BigInt
  reason     String?
  txHash     String   @unique
  timestamp  DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id])

  @@unique([proposalId, voter])
  @@index([proposalId])
  @@index([voter])
  @@index([timestamp])
}

model ProposalExecution {
  id          String   @id @default(uuid())
  proposalId  String
  executor    String
  success     Boolean
  returnData  String?
  gasUsed     BigInt?
  txHash      String   @unique
  executedAt  DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id])

  @@index([proposalId])
  @@index([executor])
  @@index([executedAt])
}

enum ProposalType {
  PARAMETER_CHANGE
  ADMIN_TRANSFER
  TREASURY_SPEND
  CONTRACT_UPGRADE
  CUSTOM
}

enum ProposalStatus {
  ACTIVE
  PASSED
  REJECTED
  EXECUTED
  CANCELLED
  EXPIRED
}

model Campaign {
  id            String         @id @default(uuid())
  campaignId    Int            @unique
  tokenId       String
  creator       String
  type          CampaignType
  status        CampaignStatus @default(ACTIVE)
  targetAmount  BigInt
  currentAmount BigInt         @default(0)
  executionCount Int           @default(0)
  startTime     DateTime
  endTime       DateTime?
  metadata      String?
  txHash        String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  completedAt   DateTime?
  cancelledAt   DateTime?

  executions CampaignExecution[]

  @@index([tokenId])
  @@index([creator])
  @@index([status])
  @@index([type])
  @@index([startTime])
  @@index([createdAt])
}

model CampaignExecution {
  id         String   @id @default(uuid())
  campaignId String
  executor   String
  amount     BigInt
  recipient  String?
  txHash     String   @unique
  executedAt DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([executor])
  @@index([executedAt])
}

enum CampaignType {
  BUYBACK
  AIRDROP
  LIQUIDITY
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

/// Stores durable state for long-running backend services.
/// Used by StellarEventListener to persist the last processed event cursor
/// so it can resume correctly after restarts without missing or replaying events.
model IntegrationState {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
